                                          取消
                                        </button>
                                      </div>
                                    </div>
                                  )}
                                </div>
                              </div>
                            )}
                          </div>

                          {/* 摺疊設定 4: 備份 */}
                          <div className="bg-[#1a1c20] rounded-[24px] border border-neutral-800 overflow-hidden">
                            <button
                              onClick={() => { playClickSound(); setActiveSettingSection(activeSettingSection === 'backup' ? null : 'backup'); }}
                              className="w-full flex justify-between items-center p-4 text-left font-black text-xs text-zinc-200 hover:bg-neutral-900"
                            >
                              <span className="flex items-center gap-2 uppercase tracking-wider">
                                <Icons.Download /> 備份與還原庫
                              </span>
                              <Icons.ChevronDown className={`transform transition-transform ${activeSettingSection === 'backup' ? 'rotate-180 text-emerald-400' : ''}`} />
                            </button>

                            {activeSettingSection === 'backup' && (
                              <div className="p-4 border-t border-neutral-800 bg-[#16171b] space-y-3 animate-fadeIn">
                                <div className="grid grid-cols-2 gap-2">
                                  <button onClick={handleExportData} className="py-2 bg-neutral-900 border border-neutral-800 text-zinc-200 text-[11px] font-black rounded-xl flex items-center justify-center gap-1.5">
                                    匯出備份 JSON
                                  </button>
                                  
                                  <label className="py-2 bg-neutral-900 border border-neutral-800 text-zinc-200 text-[11px] font-black rounded-xl flex items-center justify-center gap-1.5 cursor-pointer text-center">
                                    匯入備份 JSON
                                    <input type="file" accept=".json" onChange={handleImportData} className="hidden" />
                                  </label>
                                </div>
                                <p className="text-[10px] text-zinc-500 leading-relaxed font-bold">
                                  💡 提示：更換手機或清除瀏覽器快取前，請記得在此處點擊「匯出備份」並保存 JSON 備份。
                                </p>
                              </div>
                            )}
                          </div>

                        </div>
                      )}

                    </div>

                  </div>
                )}
              </div>

            </div>

          </div>
        </div>
      );
    }

    // 將我們的 React 應用渲染到 HTML 的 root 容器中
    const rootElement = document.getElementById('root');
    const root = ReactDOM.createRoot(rootElement);
    root.render(<App />);
  </script>

</body>
</html>
