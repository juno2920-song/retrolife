<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>iida INFOBAR Life Logger</title>
  
  <!-- 1. 引入 Tailwind CSS 網頁樣式庫 -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- 2. 引入 React 和 ReactDOM (網頁版免安裝版) -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  
  <!-- 3. 引入 Babel (用嚟直接喺網頁中解讀 React 語法) -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <style>
    /* 經典搖晃動畫 (編輯模式) */
    @keyframes jiggle {
      0% { transform: rotate(-0.8deg) translate(-0.3px, -0.3px); }
      50% { transform: rotate(0.8deg) translate(0.3px, 0.3px); }
      100% { transform: rotate(-0.8deg) translate(-0.3px, 0.3px); }
    }
    .animate-jiggle {
      animation: jiggle 0.22s ease-in-out infinite alternate;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
      animation: fadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    /* 隱藏滾動條 */
    .scrollbar-none::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-none {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* 🍏 iOS 原生級過場動畫貝氏曲線 (阻尼感切換) */
    .transition-ios {
      transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
    }
  </style>
</head>
<body class="bg-[#0d0e10] text-white">

  <!-- React 渲染的主容器 -->
  <div id="root"></div>

