    function App() {
      const [currentDate, setCurrentDate] = useState(new Date());
      const [selectedDateStr, setSelectedDateStr] = useState(getFormattedDateStr(new Date()));
      const [activeApp, setActiveApp] = useState(null); 
      const [systemTime, setSystemTime] = useState(new Date());

      // 🍏 延遲渲染狀態：解決退場過渡動畫時子頁面提前消失的問題
      const [displayedApp, setDisplayedApp] = useState(null);

      // 當 activeApp 改變時，控制 displayedApp 的延遲卸載
      useEffect(() => {
        if (activeApp !== null) {
          setDisplayedApp(activeApp);
        } else {
          // 等待 500ms（iOS 過場動畫完畢）再徹底從 DOM 中卸載子頁面
          const timer = setTimeout(() => {
            setDisplayedApp(null);
          }, 500);
          return () => clearTimeout(timer);
        }
      }, [activeApp]);

      // 編輯模式 (Jiggle Mode)
      const [isEditing, setIsEditing] = useState(false);
      const longPressTimeout = useRef(null);

      // 通知提示 Toast 訊息狀態
      const [toast, setToast] = useState({ show: false, message: '', type: 'success' });

      // 觸發自訂通知
      const showToast = (message, type = 'success') => {
        setToast({ show: true, message, type });
        setTimeout(() => {
          setToast({ show: false, message: '', type: 'success' });
        }, 3000);
      };

      // 註冊 Service Worker 進行 PWA 支援
      useEffect(() => {
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.register('./sw.js')
            .then(() => console.log("PWA Service Worker 註冊成功！"))
            .catch((err) => console.log("PWA SW 註冊失敗 (如本地預覽屬正常):", err.message));
        }
      }, []);

      // 1. 同步與一般偏好設定狀態
      const [syncSettings, setSyncSettings] = useState(() => {
        const saved = localStorage.getItem('iida_sync_settings_v4');
        return saved ? JSON.parse(saved) : {
          username: '深澤直人',
          language: 'zh-TW',
          themeSaturate: 'normal',
          googleEnabled: false,
          googleEmail: '',
          googleStatus: 'disconnected',
          googleLastSync: '從未同步',
          icloudEnabled: false,
          icloudEmail: '',
          icloudStatus: 'disconnected',
          icloudLastSync: '從未同步',
          syncInterval: 'manual',
          soundEffects: true
        };
      });

      // 設定摺疊狀態管理：'sound' | 'sync' | 'general' | 'backup' | null
      const [activeSettingSection, setActiveSettingSection] = useState(null);

      // 經典日系與 INFOBAR NISHIKIGOI 配色預設方案
      const colorPresets = {
        vermilion: { bg: 'bg-[#cf2b1f]', text: 'text-white', border: 'border-red-900/30', badge: 'bg-red-950/20 text-red-100', dot: '#cf2b1f' },
        charcoal: { bg: 'bg-[#1a1c20]', text: 'text-white', border: 'border-zinc-800', badge: 'bg-zinc-800 text-zinc-300', dot: '#4b5563' },
        beige: { bg: 'bg-[#f5f2eb]', text: 'text-neutral-900', border: 'border-[#e4dfd5]', badge: 'bg-neutral-900/10 text-neutral-800', dot: '#d4ceb8' },
        slate: { bg: 'bg-[#2e3a47]', text: 'text-white', border: 'border-slate-700/40', badge: 'bg-white/10 text-slate-100', dot: '#2e3a47' },
        mustard: { bg: 'bg-[#dca134]', text: 'text-neutral-950', border: 'border-amber-700/30', badge: 'bg-neutral-950/10 text-neutral-900', dot: '#dca134' },
        matcha: { bg: 'bg-[#4a5d4e]', text: 'text-white', border: 'border-emerald-900/20', badge: 'bg-emerald-950/20 text-emerald-100', dot: '#4a5d4e' },
        sky: { bg: 'bg-[#4b84a1]', text: 'text-white', border: 'border-sky-900/20', badge: 'bg-sky-950/20 text-sky-100', dot: '#4b84a1' }
      };

      // 瓷磚排序、大小與色彩設定
      const [tiles, setTiles] = useState(() => {
        const saved = localStorage.getItem('infobar_tile_layout_v4');
        return saved ? JSON.parse(saved) : [
          { id: 'clock', type: 'clock', size: 2, color: 'charcoal' },
          { id: 'weather', type: 'weather', size: 1, color: 'beige' },
          { id: 'calendar', type: 'calendar', size: 3, color: 'charcoal' },
          { id: 'diary', type: 'diary', size: 1, color: 'vermilion' },
          { id: 'expense', type: 'expense', size: 1, color: 'slate' },
          { id: 'todo', type: 'todo', size: 1, color: 'beige' },
          { id: 'settings', type: 'settings', size: 1, color: 'slate' }
        ];
      });

      const [draggedIndex, setDraggedIndex] = useState(null);

      // 2. 日曆行程狀態
      const [events, setEvents] = useState(() => {
        const saved = localStorage.getItem('infobar_events_v4');
        return saved ? JSON.parse(saved) : [
          { id: 'ev1', date: getFormattedDateStr(new Date()), title: '深澤直人設計講座 🎨', time: '14:00', color: 'bg-red-500', desc: '線上研討會 / NISHIKIGOI 美學探討' },
          { id: 'ev2', date: getFormattedDateStr(new Date()), title: '每日放鬆冥想 🧘‍♀️', time: '19:30', color: 'bg-blue-500', desc: '釋放日常工作壓力' }
        ];
      });

      // 3. 待辦事項狀態
      const [todos, setTodos] = useState(() => {
        const saved = localStorage.getItem('infobar_todos_v4');
        return saved ? JSON.parse(saved) : [
          { id: 't1', date: getFormattedDateStr(new Date()), text: '設計極簡 iOS PWA 佈局 💻', completed: false },
          { id: 't2', date: getFormattedDateStr(new Date()), text: '晚間 3 公里極簡慢跑 🏃', completed: true }
        ];
      });

      // 4. 日記與靈感狀態
      const [diaries, setDiaries] = useState(() => {
        const saved = localStorage.getItem('infobar_diaries_v4');
        return saved ? JSON.parse(saved) : [
          { 
            id: 'd1', 
            date: getFormattedDateStr(new Date()), 
            text: '今天我為這款生活 logger 加上了微型財務圖表，和風拼貼色塊配上極簡進度條，一眼就能掌握自己的開銷，用起來真的很療癒。', 
            category: 'diary',
            mood: '😊',
            weather: '☀️'
          }
        ];
      });

      // 5. 記帳狀態
      const [expenses, setExpenses] = useState(() => {
        const saved = localStorage.getItem('infobar_expenses_v4');
        return saved ? JSON.parse(saved) : [
          { id: 'e1', date: getFormattedDateStr(new Date()), amount: 150, category: '餐飲', description: '午餐外帶極簡日式弁當' },
          { id: 'e2', date: getFormattedDateStr(new Date()), amount: 65, category: '交通', description: '乘地鐵通勤' },
          { id: 'e3', date: getFormattedDateStr(new Date()), amount: 420, category: '購物', description: '深澤直人設計專著' }
        ];
      });

      // 網頁原生 Web Audio API 合成溫和按鍵音
      const playClickSound = () => {
        if (!syncSettings.soundEffects) return;
        try {
          const ctx = new (window.AudioContext || window.webkitAudioContext)();
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.connect(gain);
          gain.connect(ctx.destination);
          
          osc.type = 'sine';
          osc.frequency.setValueAtTime(1200, ctx.currentTime);
          osc.frequency.exponentialRampToValueAtTime(800, ctx.currentTime + 0.03);
          
          gain.gain.setValueAtTime(0.03, ctx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.03);
          
          osc.start();
          osc.stop(ctx.currentTime + 0.04);
        } catch (e) {
          console.log("音效遭系統限制播放。");
        }
      };

      // 數據保存監聽器
      useEffect(() => { localStorage.setItem('infobar_tile_layout_v4', JSON.stringify(tiles)); }, [tiles]);
      useEffect(() => { localStorage.setItem('infobar_events_v4', JSON.stringify(events)); }, [events]);
      useEffect(() => { localStorage.setItem('infobar_todos_v4', JSON.stringify(todos)); }, [todos]);
      useEffect(() => { localStorage.setItem('infobar_diaries_v4', JSON.stringify(diaries)); }, [diaries]);
      useEffect(() => { localStorage.setItem('infobar_expenses_v4', JSON.stringify(expenses)); }, [expenses]);
      useEffect(() => { localStorage.setItem('iida_sync_settings_v4', JSON.stringify(syncSettings)); }, [syncSettings]);

      // 動態刷新系統時間
      useEffect(() => {
        const timer = setInterval(() => { setSystemTime(new Date()); }, 1000);
        return () => clearInterval(timer);
      }, []);

      function getFormattedDateStr(date) {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
      }

      // 獲取指定日期的數據摘要
      function getDaySummary(dateStr) {
        const dayEvents = events.filter(ev => ev.date === dateStr);
        const dayTodos = todos.filter(t => t.date === dateStr);
        const dayDiaries = diaries.filter(d => d.date === dateStr);
        const dayExpenses = expenses.filter(e => e.date === dateStr);
        const totalExpense = dayExpenses.reduce((sum, curr) => sum + curr.amount, 0);

        return {
          hasEvents: dayEvents.length > 0,
          events: dayEvents,
          hasTodos: dayTodos.length > 0,
          todoDoneCount: dayTodos.filter(t => t.completed).length,
